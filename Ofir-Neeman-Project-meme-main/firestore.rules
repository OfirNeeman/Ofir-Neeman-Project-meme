rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // חוקים עבור אוסף המשחקים
    match /games/{roomCode} {
      
      // 1. מאפשר למצוא משחק לפי קוד (get) כדי לבדוק אם הוא קיים ולהשוות סיסמה
      // אנחנו לא מאפשרים list (חיפוש כללי) כדי שאנשים לא יוכלו לסרוק את כל החדרים הפעילים
      allow get: if true;
      
      // 2. יצירת משחק חדש (create)
      allow create: if true;
      
      // 3. עדכון המשחק (update)
      // מאפשר לשחקנים להצטרף (arrayUnion) ולמארח לעדכן סטטוסים
      allow update: if true;

      // 4. מניעת מחיקה של חדרים על ידי שחקנים אקראיים
      allow delete: if false;

      // חוק אופציונלי להגנה על שדה הסיסמה:
      // ניתן להגדיר שבעדכון (update) אסור לשנות את שדה ה-password אחרי שהוא נוצר
      // allow update: if request.resource.data.password == resource.data.password;
    }
  }
}